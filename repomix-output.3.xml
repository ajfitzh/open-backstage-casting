                                                                </div>

                                                                <div className="space-y-2">
                                                                    {uniqueTimes.map((t: any) => {
                                                                        const slotItems = dayItems.filter((i:any) => Math.abs(i.startTime - t) < 0.1);
                                                                        
                                                                        return (
