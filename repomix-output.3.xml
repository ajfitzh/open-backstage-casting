                                                                <div className="flex justify-between items-end mb-4">
                                                                    <h4 className="text-xs font-black uppercase text-zinc-500 flex items-center gap-2">
                                                                        <Calendar size={12}/> {day === 'Fri' ? 'Friday Evening' : 'Saturday Day'}
