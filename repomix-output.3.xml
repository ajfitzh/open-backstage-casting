                                                <div className="space-y-8 pl-4 border-l border-white/5">
                                                    {['Fri', 'Sat'].map(day => {
                                                        const dayItems = weekItems.filter((i:any) => i.day === day);
                                                        const uniqueTimes = Array.from(new Set(dayItems.map((i:any) => i.startTime))).sort((a:any,b:any) => a-b);

